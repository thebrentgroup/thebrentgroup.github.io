},{"type":"Container","styleId":"c1","id":"mainPage_Container_5","components":[{"type":"Component","styleId":"txtNew","id":"mainPage_Container_5_WRichText_0","dataQuery":"#219k","skin":"wysiwyg.viewer.skins.WRichTextSkin","layout":{"width":260,"height":30,"x":10,"y":10,"scale":1.0,"rotationInDegrees":0.0,"anchors":[{"distance":10,"topToTop":39,"originalValue":49,"type":"BOTTOM_TOP","locked":true,"targetComponent":"mainPage_Container_5_WPhoto_0"}],"fixedPosition":false},"componentType":"wysiwyg.viewer.components.WRichText"},{"type":"Component","styleId":"wp1","id":"mainPage_Container_5_WPhoto_0","dataQuery":"#component_78913","skin":"wysiwyg.viewer.skins.photo.RoundPhoto","layout":{"width":260,"height":86,"x":10,"y":50,"scale":1.0,"rotationInDegrees":0.0,"anchors":[{"distance":10,"topToTop":96,"originalValue":145,"type":"BOTTOM_TOP","locked":true,"targetComponent":"WRchTxt2"}],"fixedPosition":false},"propertyQuery":"mainPage_Container_5_WPhoto_0","componentType":"wysiwyg.viewer.components.WPhoto"},{"type":"Component","styleId":"txtNew","id":"WRchTxt2","dataQuery":"#fqk","skin":"wysiwyg.viewer.skins.WRichTextSkin","layout":{"width":255,"height":259,"x":13,"y":146,"scale":1.0,"rotationInDegrees":0.0,"anchors":[{"distance":10,"topToTop":180,"originalValue":325,"type":"BOTTOM_TOP","locked":true,"targetComponent":"StBttn4"}],"fixedPosition":false},"propertyQuery":"mobile_WRchTxt2","componentType":"wysiwyg.viewer.components.WRichText"},{"type":"Component","styleId":"style-ij0zpo6p","id":"StBttn4","dataQuery":"#c1qs3","skin":"wysiwyg.viewer.skins.button.ShinyButtonInverted","layout":{"width":107,"height":40,"x":87,"y":415,"scale":1.0,"rotationInDegrees":0.0,"anchors":[{"distance":10,"topToTop":325,"originalValue":375,"type":"BOTTOM_PARENT","locked":true,"targetComponent":"mainPage_Container_5"}],"fixedPosition":false},"propertyQuery":"c3qj","componentType":"wysiwyg.viewer.components.SiteButton"}],"skin":"wysiwyg.viewer.skins.area.DefaultAreaSkin","layout":{"width":280,"height":465,"x":20,"y":1700,"scale":1.0,"rotationInDegrees":0.0,"anchors":[{"distance":10,"topToTop":475,"originalValue":2175,"type":"BOTTOM_TOP","locked":true,"targetComponent":"i8hrz0vp"}],"fixedPosition":false},"componentType":"mobile.core.components.Container"},{"type":"Component","styleId":"htco1","id":"i8hrz0vp","dataQuery":"#c1iao","skin":"wysiwyg.viewer.skins.HtmlComponentSkin","layout":{"width":76,"height":37,"x":122,"y":2175,"scale":1.0,"rotationInDegrees":0.0,"anchors":[{"distance":10,"topToTop":2175,"originalValue":1367,"type":"BOTTOM_PARENT","locked":true,"targetComponent":"mainPage"}],"fixedPosition":false},"componentType":"wysiwyg.viewer.components.HtmlComponent"},{"type":"Component","styleId":"txtNew","id":"comp-ij11he6b","dataQuery":"#dataItem-ij11he6d","layout":{"width":280,"height":3,"x":20,"y":1685,"scale":1.0,"rotationInDegrees":0.0,"anchors":[{"distance":12,"topToTop":15,"originalValue":1700,"type":"BOTTOM_TOP","locked":true,"targetComponent":"mainPage_Container_5"}],"fixedPosition":false},"propertyQuery":"propItem-ij11he6f","componentType":"wysiwyg.viewer.components.WRichText"}],"dataQuery":"#mainPage","skin":"wysiwyg.viewer.skins.page.TransparentPageSkin","layout":{"width":980,"height":1367,"x":0,"y":0,"scale":1.0,"rotationInDegrees":0.0,"anchors":[],"fixedPosition":false},"componentType":"mobile.core.components.Page"},"data":{"document_data":{"1ayg":{"type":"PageLink","id":"1ayg","metaData":{"isPreset":false,"schemaVersion":"1.0","isHidden":false},"pageId":"#galleryPage"},"1mf2":{"type":"StyledText","id":"1mf2","metaData":{"isPreset":false,"schemaVersion":"1.0","isHidden":false},"text":"<p style=\"font-size: 14px;\" class=\"font_7\"><span class=\"color_15\"><span style=\"font-size:14px;\"><span style=\"font-weight:bold;\">MSI was created to integrate science across many disciplines in order to make radical leaps in our ability to understand the disease process, including rare diseases, infectious disease and cancer, in both developed and the developing world.</span></span></span></p>\n\n<p style=\"font-size: 14px;\" class=\"font_7\">&nbsp;</p>\n\n<p style=\"font-size: 14px;\" class=\"font_7\"><span class=\"color_15\"><span style=\"font-size:14px;\"><span style=\"font-weight:bold;\">Our major platform is the molecular basis of our human and environmental microbiome and its relationship to our immune system, stem cells and cancer. </span></span></span></p>\n\n<p style=\"font-size: 14px;\" class=\"font_7\">&nbsp;</p>\n\n<p style=\"font-size: 14px;\" class=\"font_7\"><span class=\"color_15\"><span style=\"font-size:14px;\"><span style=\"font-weight:bold;\">We will utilize novel technology to address the unmet needs in healthcare to improve the quality of life and productivity of society.</span></span></span></p>\n\n<p style=\"font-size: 14px;\" class=\"font_7\">&nbsp;</p>\n","stylesMapId":"CK_EDITOR_PARAGRAPH_STYLES","linkList":[]},"1trs":{"type":"StyledText","id":"1trs","metaData":{"isPreset":false,"schemaVersion":"1.0","isHidden":false},"text":"<p style=\"font-size: 14px;\" class=\"font_7\"><span class=\"color_15\"><span style=\"font-size:14px;\"><span style=\"font-weight:bold;\">To develop a sustainable path toward integration of diverse scientific disciplines, we have assembled a team with a broad variety of skills, knowledge and passions.</span></span></span></p>\n\n<p style=\"font-size: 14px;\" class=\"font_7\">&nbsp;</p>\n\n<p style=\"font-size: 14px;\" class=\"font_7\"><span class=\"color_15\"><span style=\"font-size:14px;\"><span style=\"font-weight:bold;\">Our team is made up of academic and industry scientists, entrepreneurs and intellectual property experts.</span></span></span></p>\n\n<p style=\"font-size: 14px;\" class=\"font_7\">&nbsp;</p>\n\n<p style=\"font-size: 14px;\" class=\"font_7\"><span class=\"color_15\"><span style=\"font-size:14px;\"><span style=\"font-weight:bold;\">Our culture is centered on our strong sense of collaboration and our desire to \"raise all boats,\" maximizing the potential of all our partners.&nbsp;</span></span></span></p>\n\n<p style=\"line-height: 1.3em;\" class=\"font_8\">&nbsp;</p>\n","stylesMapId":"CK_EDITOR_PARAGRAPH_STYLES","linkList":[]},"1w7t":{"type":"PageLink","id":"1w7t","metaData":{"isPreset":false,"schemaVersion":"1.0","isHidden":false},"pageId":"#c2y2"},"1wct":{"type":"StyledText","id":"1wct","metaData":{"isPreset":false,"schemaVersion":"1.0","isHidden":false},"text":"<h5 style=\"line-height: 1.2em;\" class=\"font_5\"><span style=\"line-height: 1.2em;\"><span class=\"color_20\">Our Mission</span></span></h5>\n","stylesMapId":"CK_EDITOR_PARAGRAPH_STYLES","linkList":[]},"219k":{"type":"StyledText","id":"219k","metaData":{"isPreset":false,"schemaVersion":"1.0","isHidden":false},"text":"<h5 style=\"line-height: 1.2em;\" class=\"font_5\"><span style=\"line-height: 1.2em;\"><span class=\"color_20\">Our History</span></span></h5>\n","stylesMapId":"CK_EDITOR_PARAGRAPH_STYLES","linkList":[]},"bv6":{"type":"PageLink","id":"bv6","metaData":{"isPreset":false,"schemaVersion":"1.0","isHidden":false},"pageId":"#czxh"},"c148j":{"type":"LinkableButton","id":"c148j","metaData":{"isPreset":false,"schemaVersion":"1.0","isHidden":false},"label":"More","link":"#bv6"},"c17yd":{"type":"LinkableButton","id":"c17yd","metaData":{"isPreset":false,"schemaVersion":"1.0","isHidden":false},"label":"More","link":"#1ayg"},"c1iao":{"type":"HtmlComponent","id":"c1iao","metaData":{"isPreset":false,"schemaVersion":"1.0","isHidden":false},"url":"html/b1dc1d_7abd18bb67ee95ec55ae740bf3ec76d2.html","sourceType":"htmlEmbedded","freezeFrame":false},"c1qs3":{"type":"LinkableButton","id":"c1qs3","metaData":{"isPreset":false,"schemaVersion":"1.0","isHidden":false},"label":"More","link":"#1w7t"},"c1ylh":{"type":"Image","id":"c1ylh","metaData":{"isPreset":true,"schemaVersion":"2.0","isHidden":false},"title":"","uri":"84770f_78ebe485853b437fabfdd6d9ebf3b667.jpg","description":"","width":616,"height":487,"alt":"","originalImageDataRef":"#original_image_y3p"},"component_14098":{"type":"Image","id":"component_14098","metaData":{"isPreset":false,"schemaVersion":"2.0","isHidden":false},"title":"Screen Shot 2016-01-04 at 10.16.59 PM_edited_edited.png","uri":"b1dc1d_41a1beea44d74bea9b9a77ebace3d6fb.png","description":"","width":363,"height":111,"alt":"","originalImageDataRef":"#dataItem-ijqdeh4f"},"component_55150":{"type":"Image","id":"component_55150","metaData":{"isPreset":true,"schemaVersion":"2.0","isHidden":false},"title":"","uri":"84770f_dec41f79f196959a09f9a7d88a507b86.jpg","description":"","width":1280,"height":853,"alt":""},"component_78913":{"type":"Image","id":"component_78913","metaData":{"isPreset":true,"schemaVersion":"2.0","isHidden":false},"title":"","uri":"84770f_275b95cb82490089c48b49d3be07e990.jpg","description":"","width":500,"height":345,"alt":""},"ct0m":{"type":"StyledText","id":"ct0m","metaData":{"isPreset":false,"schemaVersion":"1.0","isHidden":false},"text":"<p style=\"font-size: 16px;\" class=\"font_8\"><span class=\"color_11\"><span style=\"font-size:16px;\"><span style=\"font-family:jura,sans-serif;\">The Molecular Sciences Institute (MSI) is an independent, non-profit research laboratory and a 501(c)(3) organization. The MSI was founded in June, 1996 by Dr. Sydney Brenner who received a Nobel Prize in 2002 for his contributions towards discoveries about how genes regulate organ growth and the process of programmed cell death.</span></span></span></p>\n\n<p style=\"font-size: 16px;\" class=\"font_8\">&nbsp;</p>\n\n<p style=\"font-size: 16px;\" class=\"font_8\"><span class=\"color_11\"><span style=\"font-size:16px;\"><span style=\"font-family:jura,sans-serif;\">He understood that a key challenge for biological sciences in the first decade of the 21st century would be to distill knowledge and understanding from the surplus of data produced by new observation- and computation-based technologies to fuel the inevitable convergence of Biology, Human Health and Technology.</span></span></span></p>\n","stylesMapId":"CK_EDITOR_PARAGRAPH_STYLES","linkList":[]},"customBgImg7d1":{"type":"BackgroundMedia","id":"customBgImg7d1","metaData":{"isPreset":false,"schemaVersion":"2.0","isHidden":false},"color":"#3D9BE9","alignType":"top","fittingType":"legacy_tile","scrollType":"scroll","colorOverlay":"","colorOverlayOpacity":0.0},"dataItem-ij11he6d":{"type":"StyledText","id":"dataItem-ij11he6d","metaData":{"isPreset":false,"schemaVersion":"1.0","isHidden":false},"text":"<p style=\"font-size: 35px;\" class=\"font_7\"><span style=\"text-shadow:rgba(0, 0, 0, 0.498039) -1px -1px 0px, rgba(0, 0, 0, 0.498039) -1px 1px 0px, rgba(0, 0, 0, 0.498039) 1px 1px 0px, rgba(0, 0, 0, 0.498039) 1px -1px 0px;\"><span class=\"color_11\">We are currently updating our website. Please visit us again&nbsp;soon.</span></span></p>\n\n<p style=\"font-size: 47px;\" class=\"font_7\"><span style=\"font-size:47px;\"><span style=\"text-shadow:rgba(0, 0, 0, 0.498039) -1px -1px 0px, rgba(0, 0, 0, 0.498039) -1px 1px 0px, rgba(0, 0, 0, 0.498039) 1px 1px 0px, rgba(0, 0, 0, 0.498039) 1px -1px 0px;\"><span class=\"color_11\">~ The MSI Team</span></span></span></p>\n","stylesMapId":"CK_EDITOR_PARAGRAPH_STYLES","linkList":[]},"dataItem-ijqdeh4f":{"type":"Image","id":"dataItem-ijqdeh4f","metaData":{"isPreset":false,"schemaVersion":"2.0","isHidden":false},"title":"Screen Shot 2016-01-04 at 10.16.59 PM_edited_edited.png","uri":"b1dc1d_0fffae973c9c4d32b5458131d4ca017b.png","width":453,"height":111,"alt":""},"fqk":{"type":"StyledText","id":"fqk","metaData":{"isPreset":false,"schemaVersion":"1.0","isHidden":false},"text":"<p style=\"line-height: 1.3em; font-size: 14px;\" class=\"font_8\"><span class=\"color_15\"><span style=\"font-family:jura,sans-serif;\"><span style=\"font-weight:bold;\"><span style=\"font-size:14px;\">Originally founded in1996 by Dr. Sydney Brenner who received a Nobel Prize in 2002, MSI has been at the forefront of cutting edge science.</span></span></span></span></p>\n\n<p style=\"line-height: 1.3em; font-size: 14px;\" class=\"font_8\">&nbsp;</p>\n\n<p style=\"line-height: 1.3em; font-size: 14px;\" class=\"font_8\"><span class=\"color_15\"><span style=\"font-family:jura,sans-serif;\"><span style=\"font-weight:bold;\"><span style=\"font-size:14px;\">In early 2014, MSI relocated to Milpitas, CA in the heart of Silicon Valley, the birthplace of technology, and began, with the help of an experienced task force, to execute the mission and science critical to positively impact society.&nbsp;</span></span></span></span></p>\n","stylesMapId":"CK_EDITOR_PARAGRAPH_STYLES","linkList":[]},"mainPage":{"type":"Page","id":"mainPage","metaData":{"isPreset":false,"schemaVersion":"1.0","isHidden":false},"title":"Home","hideTitle":true,"icon":"","descriptionSEO":"","metaKeywordsSEO":"","pageTitleSEO":"","pageUriSEO":"home","hidePage":false,"underConstruction":false,"tpaApplicationId":0,"pageSecurity":{"requireLogin":false},"indexable":true,"isLandingPage":false,"pageBackgrounds":{"desktop":{"custom":true,"ref":"#mainPage_ij10g8yu1_bg","isPreset":false},"mobile":{"custom":true,"ref":"#customBgImg7d1","isPreset":true}}},"mainPage_ij10g8yu1_bg":{"type":"BackgroundMedia","id":"mainPage_ij10g8yu1_bg","metaData":{"isPreset":false,"schemaVersion":"2.0","isHidden":false},"color":"#3D9BE9","alignType":"top","fittingType":"legacy_tile","scrollType":"fixed","colorOverlay":"","colorOverlayOpacity":0.0},"original_image_y3p":{"type":"Image","id":"original_image_y3p","metaData":{"isPreset":true,"schemaVersion":"2.0","isHidden":false},"title":"","uri":"84770f_951908c39cc6be82a72c1c5b607820f9.jpg","description":"","width":1280,"height":572,"alt":""},"s7x":{"type":"StyledText","id":"s7x","metaData":{"isPreset":false,"schemaVersion":"1.0","isHidden":false},"text":"<h3 style=\"line-height: 1.1em; font-size: 36px;\" class=\"font_3\"><span style=\"text-shadow:rgba(0, 0, 0, 0.498039) -1px -1px 0px, rgba(0, 0, 0, 0.498039) -1px 1px 0px, rgba(0, 0, 0, 0.498039) 1px 1px 0px, rgba(0, 0, 0, 0.498039) 1px -1px 0px;\"><span style=\"font-size:36px;\"><span style=\"line-height:1.1em;\"><span class=\"color_11\">“Great Science Through Collaboration\"</span></span></span></span></h3>\n","stylesMapId":"CK_EDITOR_PARAGRAPH_STYLES","linkList":[]},"vmn":{"type":"StyledText","id":"vmn","metaData":{"isPreset":false,"schemaVersion":"1.0","isHidden":false},"text":"<h5 style=\"line-height: 1.2em;\" class=\"font_5\"><span style=\"line-height: 1.2em;\"><span class=\"color_20\">Our Team</span></span></h5>\n","stylesMapId":"CK_EDITOR_PARAGRAPH_STYLES","linkList":[]}},"theme_data":{},"component_properties":{"c1wll":{"type":"WPhotoProperties","metaData":{"schemaVersion":"1.0"},"displayMode":"fill","onClickBehavior":"goToLink"},"c3qj":{"type":"ButtonProperties","metaData":{"schemaVersion":"1.0"},"align":"center","margin":0},"c8ed":{"type":"ButtonProperties","metaData":{"schemaVersion":"1.0"},"align":"center","margin":0},"cx4k":{"type":"ButtonProperties","metaData":{"schemaVersion":"1.0"},"align":"center","margin":0},"mainPage_Container_1_WPhoto_0":{"type":"WPhotoProperties","metaData":{"schemaVersion":"1.0"},"displayMode":"fitWidth","onClickBehavior":"goToLink"},"mainPage_Container_5_WPhoto_0":{"type":"WPhotoProperties","metaData":{"schemaVersion":"1.0"},"displayMode":"fill","onClickBehavior":"goToLink"},"mainPage_WPhoto_1":{"type":"WPhotoProperties","metaData":{"schemaVersion":"1.0"},"displayMode":"fill","onClickBehavior":"goToLink"},"mobile_WRchTxt0":{"type":"WRichTextProperties","metaData":{"schemaVersion":"1.0"},"brightness":1.0},"mobile_WRchTxt2":{"type":"WRichTextProperties","metaData":{"schemaVersion":"1.0"},"brightness":1.0},"mobile_i4nm1vfg":{"type":"WRichTextProperties","metaData":{"schemaVersion":"1.0"},"brightness":1.0},"mobile_mainPage_Container_1_WRichText_0":{"type":"WRichTextProperties","metaData":{"schemaVersion":"1.0"},"brightness":1.0},"mobile_mainPage_Container_2_WRichText_0":{"type":"WRichTextProperties","metaData":{"schemaVersion":"1.0"},"brightness":1.0},"propItem-ij11he6f"